PORT=5000
CORS_ORIGINS=*

# Carpetas — en producción Linux usar rutas absolutas del mount (ej. /mnt/signa/...)
# Windows/red: UNC \\Servidor\Carpeta
BANDEJA_ENTRADA=datos/Bandeja_Entrada
REMITOS_FIRMADOS=datos/Remitos_Firmados
# WATCHDOG_USE_POLLING=1  # recomendado en carpetas SMB/NFS montadas en Linux
# WATCHDOG_POLLING_TIMEOUT=2.5

# Linux + clientes Windows: mapeo mount -> UNC (Abrir ubicación)
# STORAGE_CLIENT_PATH_MAP=/mnt/signa/transferencias=\\SERVIDOR\\Transferencias;/mnt/signa/bandeja=\\SERVIDOR\\BandejaEntrada

LOG_DIR=logs

# IPs permitidas — separadas por comas, soporta CIDR (192.168.0.0/24)
# Usar * para permitir todas
ALLOWED_IPS=*

# Autenticación legacy (token fijo, desactivado si usás JWT)
AUTH_ENABLED=false
AUTH_TOKEN=remitos-2024-token-secreto

# Base de datos PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/remitos

# JWT — cambiá esto en producción
JWT_SECRET=change-me-in-production

# Superadmin inicial (usado solo por seed.py)
SUPERADMIN_EMAIL=admin@remitos.local
SUPERADMIN_PASSWORD=Admin1234!

# Tango SQL Server (mismo host/usuario para todas las bases)
TANGO_HOST=
TANGO_PORT=1433
TANGO_USERNAME=
TANGO_PASSWORD=
# Legacy: si solo hay una base, puede usarse TANGO_DB_NAME
# Usar TANGO_DB_SAN_RAFAEL y TANGO_DB_CTC (no repetir TANGO_DB_NAME: el último pisa al anterior)
TANGO_DB_SAN_RAFAEL=SAN_RAFAEL_2011
TANGO_DB_CTC=CTC
TANGO_QUERY_TIMEOUT=60

# Rutas: TRANSFERENCIAS_ROOT / apartado.destino_path = carpeta padre «Transferencias».
# Firmados: Transferencias/TRANSFERENCIAS_SAN_RAFAEL|CTC/Importante|Regulares/Año/mes
# Pendientes: BANDEJA_ENTRADA/SAN_RAFAEL_2011|CTC/*.pdf
TRANSFERENCIAS_ROOT=datos/Transferencias
BANDEJA_ENTRADA=datos/Bandeja_Entrada

